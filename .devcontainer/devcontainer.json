// See https://aka.ms/vscode-remote/devcontainer.json for format details.
// "image": "ghcr.io/ludeeus/devcontainer/integration:latest",
{
    "build": {
        "dockerfile": "Dockerfile"
    },
    "name": "Versatile Thermostat integration",
    "appPort": ["8123:8123"],
    // "postCreateCommand": "container install",
    "postCreateCommand": "./container dev-setup",
    "mounts": [
        "source=${localEnv:HOME}${localEnv:USERPROFILE}/.ssh,target=/home/vscode/.ssh,type=bind,consistency=cached",
        // comment/uncomment/adapt this to get some usefull cards
        // define a VTHERM_PROJECTS_HOME env variable or adapt the following paths. On Mac copy and adapt scripts/environment.vtherm.plist in ~/Library/LaunchAgents/environment.vtherm.plist
        // then execute this commands:
        // launchctl bootout gui/$(id -u) ~/Library/LaunchAgents/environment.vtherm.plist 2>/dev/null
        // launchctl bootstrap gui/$(id -u) ~/Library/LaunchAgents/environment.vtherm.plist
        // launchctl kickstart -k gui/$(id -u)/environment.vtherm
        // launchctl getenv VTHERM_PROJECTS_HOME
        //
        // the versatile-thermostat-ui-card
        "source=/Users/jmcollin/SugarSync/Projets/home-assistant/versatile-thermostat-ui-card/dist,target=/workspaces/versatile_thermostat/config/www/community/versatile-thermostat-ui-card,type=bind",
        // the auto-tpi-learning-card
        "source=/Users/jmcollin/SugarSync/Projets/home-assistant/auto-tpi-learning-card/dist,target=/workspaces/versatile_thermostat/config/www/community/auto-tpi-learning-card,type=bind",
        // the climate-replication plugin
        "source=/Users/jmcollin/SugarSync/Projets/home-assistant/vtherm_climate_replication/custom_components/vtherm_climate_replication,target=/workspaces/versatile_thermostat/custom_components/vtherm_climate_replication,type=bind",
        // the Smart PI plugin
        "source=/Users/jmcollin/SugarSync/Projets/home-assistant/vtherm_smartpi/custom_components/vtherm_smartpi,target=/workspaces/versatile_thermostat/custom_components/vtherm_smartpi,type=bind",
        // the heating simulator from Caiussererus
        "source=/Users/jmcollin/SugarSync/Projets/home-assistant/heating-simulator,target=/workspaces/versatile_thermostat/custom_components/heating_simulator,type=bind",
        // the vtherm_hysteresis VTherm plugin
        "source=/Users/jmcollin/SugarSync/Projets/home-assistant/vtherm_hysteresis/custom_components/vtherm_hysteresis,target=/workspaces/versatile_thermostat/custom_components/vtherm_hysteresis,type=bind",
        // the vtherm_pellet_stove VTherm plugin
        "source=/Users/jmcollin/SugarSync/Projets/home-assistant/vtherm_pellet_stove/custom_components/vtherm_pellet_stove,target=/workspaces/versatile_thermostat/custom_components/vtherm_pellet_stove,type=bind"
    ],
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-python.pylint",
                // Doesn't work (crash). Default in python is to use Jedi see Settings / Python / Default Language
                // "ms-python.vscode-pylance",
                "ms-python.isort",
                "ms-python.black-formatter",
                "redhat.vscode-yaml",
                "github.vscode-pull-request-github",
                "ryanluker.vscode-coverage-gutters",
                "ferrierbenjamin.fold-unfold-all-icone",
                "donjayamanne.githistory",
                "waderyan.gitblame",
                "keesschollaart.vscode-home-assistant",
                "vscode.markdown-math",
                "yzhang.markdown-all-in-one",
                "github.vscode-github-actions",
                "azuretools.vscode-docker",
                "huizhou.githd",
                "github.copilot",
                "bierner.markdown-mermaid"
            ],
            "settings": {
                "files.eol": "\n",
                "editor.tabSize": 4,
                "terminal.integrated.profiles.linux": {
                    "bash": {
                        "path": "bash",
                        "args": []
                    }
                },
                "terminal.integrated.defaultProfile.linux": "bash",
                // "terminal.integrated.shell.linux": "/bin/bash",
                "python.pythonPath": "/usr/bin/python3",
                "python.analysis.autoSearchPaths": true,
                "pylint.lintOnChange": false,
                "python.formatting.provider": "black",
                "python.formatting.blackArgs": ["--line-length", "180"],
                "python.formatting.blackPath": "/usr/local/py-utils/bin/black",
                "editor.formatOnPaste": false,
                "editor.formatOnSave": true,
                "editor.formatOnType": true,
                "files.trimTrailingWhitespace": true
                // "python.experiments.optOutFrom": ["pythonTestAdapter"],
                // "python.analysis.logLevel": "Trace"
            }
        }
    }
}
